<%- include('partials/userHeader', { title: 'confirmation' }) %>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>

    :root{
      --cream:#f5f0e8;
      --cream-dark:#ede8de;
      --border:#ddd5c8;
      --text:#2a1a1a;
      --muted:#7a6a5a;
      --burgundy:#5c1a1a;
      --green:#4a7a4a;
    }

    body{
      background:var(--cream);
      font-family:'Montserrat',sans-serif;
      color:var(--text);
    }

    .brand{
      font-family:'Cormorant Garamond',serif;
      font-style:italic;
      font-size:1.5rem;
      font-weight:700;
      letter-spacing:2px;
      text-decoration:none;
      color:#2e0202;
    }

    .topbar{
      border-bottom:1px solid var(--border);
      padding: 0;
    }

    .success-icon{
      width:70px;
      height:70px;
      background:var(--green);
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      margin:auto;
    }

    .success-icon svg{
      width:30px;
      stroke:white;
      stroke-width:2.5;
      fill:none;
    }

    .title{
      font-family:'Playfair Display',serif;
      font-size:2.5rem;
      margin-top:20px;
    }

    .subtitle{
      font-family:'Cormorant Garamond',serif;
      font-style:italic;
      color:var(--muted);
      font-size:1.1rem;
    }

    .order-box{
      background:var(--cream-dark);
      border:1px solid var(--border);
      padding:12px 20px;
      display:inline-flex;
      gap:10px;
      margin-top:20px;
    }

    .order-box .label{
      font-size:.7rem;
      letter-spacing:.15em;
      color:var(--muted);
      font-weight:600;
    }

    .order-box .value{
      font-family:'Cormorant Garamond',serif;
      font-size:1rem;
    }

    .section-title{
      font-size:.7rem;
      letter-spacing:.18em;
      font-weight:600;
      color:var(--muted);
      border-bottom:1px solid var(--border);
      padding-bottom:10px;
      margin-bottom:20px;
    }

    .item-card{
      border-bottom:1px solid var(--border);
      padding:18px 0;
    }

    .item-img{
      width:75px;
      height:75px;
      object-fit:cover;
      background:#ddd;
    }

    .item-name{
      font-family:'Playfair Display',serif;
      font-size:1rem;
    }

    .item-qty{
      font-size:.7rem;
      letter-spacing:.1em;
      color:var(--muted);
    }

    .summary-box,
    .address-box{
      background:var(--cream-dark);
      padding:25px;
      height:100%;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      margin-bottom:12px;
    }

    .summary-row .label{
      font-size:.7rem;
      letter-spacing:.12em;
      color:var(--muted);
    }

    .summary-total{
      border-top:1px solid var(--border);
      padding-top:40px;
      margin-top:15px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .summary-total .amount{
      font-size:1.8rem;
      font-family:'Playfair Display',serif;
    }

    .status-badge{
      display:inline-flex;
      align-items:center;
      gap:6px;
      background:#eaf3ea;
      color:var(--green);
      padding:8px 14px;
      font-size:.7rem;
      letter-spacing:.14em;
      font-weight:600;
    }

    .status-dot{
      width:6px;
      height:6px;
      border-radius:50%;
      background:currentColor;
    }

    .btn-custom{
      background:var(--burgundy);
      color:white;
      padding:14px 30px;
      border:none;
      font-size:.75rem;
      letter-spacing:.18em;
      font-weight:600;
    }

    .btn-custom:hover{
      background:#451212;
      color:white;
    }

    .btn-outline-custom{
      border:1px solid var(--border);
      padding:14px 30px;
      font-size:.75rem;
      letter-spacing:.18em;
      font-weight:600;
      background:transparent;
    }

  </style>
</head>

<body>

  <!-- Header -->

  <div class="topbar">
    <div class="container d-flex justify-content-between align-items-center">

      <!-- <a href="/" class="brand">
        Emprtz
      </a> -->

      <!-- <a href="/orders" class="text-decoration-none text-muted small">
        MY ORDERS
      </a> -->

    </div>
  </div>

  <!-- Main -->

  <div class="container py-5">

    <!-- Success -->

    <div class="text-center mb-5">

      <div class="success-icon">
        <svg viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <h1 class="title">
        Thank you, your order is confirmed
      </h1>

      <p class="subtitle">
        Thank you,
        <span id="customer-name">Customer</span>.
        Your order is on its way.
      </p>

      <div class="order-box">

        <span class="label">
          ORDER ID
        </span>

        <span class="value" id="order-id">
          #000000
        </span>

      </div>

    </div>

    <!-- Items -->

    <div class="mb-5">

      <div class="section-title">
        ITEMS ORDERED
      </div>

      <div id="order-items">

      </div>

    </div>

    <!-- Summary + Address -->

    <div class="row g-4 mb-5">

      <!-- Summary -->

      <div class="col-lg-6">

        <div class="summary-box">

          <div class="section-title">
            PAYMENT SUMMARY
          </div>

          <div class="summary-row">
            <span class="label">SUBTOTAL</span>
            <span id="subtotal">₹0</span>
          </div>

          <div class="summary-row">
            <span class="label">SHIPPING</span>
            <span id="shipping">₹0</span>
          </div>

          <div class="summary-row">
            <span class="label">DISCOUNT</span>
            <span id="discount">₹0</span>
          </div>

          <div class="summary-total">

            <span>Total Paid</span>

            <span class="amount" id="total">
              ₹0
            </span>

          </div>

        </div>

      </div>

      <!-- Address -->

      <div class="col-lg-6">

        <div class="address-box">

          <div class="section-title">
            DELIVERY ADDRESS
          </div>

          <h5 id="address-name">
            Customer Name
          </h5>

          <div
            id="address-lines"
            class="text-muted"
            style="line-height:1.8;"
          >
            Address here
          </div>

        </div>

      </div>

    </div>

    <!-- Status -->

    <div class="mb-5">

      <div class="section-title">
        ORDER STATUS
      </div>

      <div class="d-flex flex-wrap align-items-center gap-3">

        <div class="status-badge">

          <span class="status-dot"></span>

          <span id="order-status">
            PAID
          </span>

        </div>

        <span
          id="created-date"
          class="text-muted"
        >
          Placed on 22 May 2026
        </span>

      </div>

    </div>

   

    <div class="d-flex flex-wrap gap-3">

      <a href="/collection" class="btn btn-custom">
        CONTINUE SHOPPING
      </a>

       <a href="/orderDetail" id="view-order-btn" class="btn btn-custom">
      VIEW MY ORDERS
      </a>

    </div>

  </div>

  <%- include('partials/userFooter') %>
 <script src="/confirmation.js"></script> 
    