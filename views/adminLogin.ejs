<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<header class="p-3 bg-light">
  <h4>Admin Login</h4>
</header>

<div class="d-flex justify-content-center align-items-center" style="height: 100vh; background: linear-gradient(135deg, #43cea2, #185a9d);">
  
  <div class="card p-4 shadow" style="width: 350px;">
    <h4 class="text-center mb-3">Admin Login</h4>

    <form method="POST" action="/admin/login">
      <input type="email" name="email" class="form-control mb-3" placeholder="Email" required>
      <input type="password" name="password" class="form-control mb-3" placeholder="Password" required>

      <button class="btn w-100" style="background:#185a9d; color:white;">Login</button>
    </form>

    <% if (error) { %>
      <p class="text-danger text-center mt-2"><%= error %></p>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>

</body>
</html>