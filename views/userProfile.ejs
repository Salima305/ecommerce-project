<%- include('partials/userHeader', { title: 'userProfile' }) %>

  <style>
    
    :root {
      --cream:        #f5f0e8;
      --dark:         #2e0303;
      --accent:       #c0392b;
      --light-border: #ddd5c8;
      --muted:        #7a6a62;
      --surface:      #faf7f2;
      --gold:         #b8924a;
      --font-serif:   'Playfair Display', serif;
      --font-sans:    'Lato', sans-serif;
    }

    .profile-header {
      max-width: 1100px;
      margin: 0 auto;
      padding: 50px 40px 30px;
      border-bottom: 1px solid var(--light-border);
    }

    .profile-header .page-eyebrow {
      font-size: 0.68rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .profile-header h1 {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(2.6rem, 6vw, 5rem);
      color: var(--dark);
      line-height: 1.1;
    }

    .profile-layout {
      max-width: 1100px;
      margin: 0 auto;
      padding: 50px 40px 80px;
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 50px;
      align-items: start;
    }

   
    .profile-sidebar {
      position: sticky;
      top: 90px;
    }

    .avatar-wrap {
      width: 120px;
      height: 120px;
      border: 2px solid var(--light-border);
      overflow: hidden;
      margin-bottom: 20px;
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .avatar-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

   .avatar-placeholder{
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  background:#e8ddd0;
  color:var(--dark);
  font-size:48px;
  font-weight:600;
  text-transform:uppercase;
}

    .sidebar-name {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--dark);
      line-height: 1.2;
      margin-bottom: 4px;
    }

    .sidebar-handle {
      font-size: 0.78rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 20px;
    }

    .sidebar-stat-row {
      display: flex;
      gap: 20px;
      padding: 18px 0;
      border-top: 1px solid var(--light-border);
      border-bottom: 1px solid var(--light-border);
      margin-bottom: 28px;
    }

    .sidebar-stat { text-align: center; }

    .sidebar-stat .stat-num {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--dark);
      display: block;
    }

    .sidebar-stat .stat-label {
      font-size: 0.65rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .sidebar-nav {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .sidebar-nav li a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--dark);
      text-decoration: none;
      border-left: 2px solid transparent;
      transition: all 0.2s;
    }

    .sidebar-nav li a:hover,
    .sidebar-nav li a.active {
      color: var(--accent);
      border-left-color: var(--accent);
      background: rgba(192, 57, 43, 0.04);
    }

    .sidebar-nav li a i { font-size: 1rem; opacity: 0.7; }

    
    .profile-main { min-width: 0; }

   
    .section-title {
      font-size: 0.68rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 22px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--light-border);
    }

   
    .info-card {
      background: var(--surface);
      border: 1px solid var(--light-border);
      padding: 30px 32px;
      margin-bottom: 36px;
    }

    .info-card .card-heading {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.25rem;
      font-weight: 400;
      color: var(--dark);
      margin-bottom: 24px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 32px;
    }

    .info-field label {
      display: block;
      font-size: 0.65rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }

    .info-field .field-value {
      font-size: 0.95rem;
      color: var(--dark);
      font-weight: 400;
    }

    .info-field input.form-control,
    .info-field select.form-select {
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--light-border);
      border-radius: 0;
      padding: 4px 0;
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--dark);
      box-shadow: none;
      transition: border-color 0.2s;
    }

    .info-field input.form-control:focus,
    .info-field select.form-select:focus {
      outline: none;
      border-bottom-color: var(--accent);
      box-shadow: none;
      background: transparent;
    }

    .edit-actions {
      display: flex;
      gap: 12px;
      margin-top: 28px;
      padding-top: 22px;
      border-top: 1px solid var(--light-border);
    }

    .btn-emprtz {
      font-size: 0.7rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      padding: 10px 24px;
      border-radius: 0;
      font-family: var(--font-sans);
      transition: all 0.25s;
      cursor: pointer;
    }

    .btn-emprtz-primary {
      background: var(--dark);
      color: var(--cream);
      border: 1px solid var(--dark);
    }

    .btn-emprtz-primary:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .btn-emprtz-outline {
      background: transparent;
      color: var(--dark);
      border: 1px solid var(--light-border);
    }

    .btn-emprtz-outline:hover {
      border-color: var(--dark);
    }

    .btn-emprtz-danger {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    .btn-emprtz-danger:hover {
      background: var(--accent);
      color: #fff;
    }

    .order-item {
      border: 1px solid var(--light-border);
      margin-bottom: 16px;
      display: grid;
      grid-template-columns: 80px 1fr auto;
      align-items: center;
      gap: 20px;
      padding: 18px 20px;
      transition: border-color 0.2s;
    }

    .order-item:hover { border-color: var(--dark); }

    .order-thumb {
      width: 80px;
      height: 80px;
      object-fit: cover;
      display: block;
      background: var(--light-border);
      flex-shrink: 0;
    }

    .order-thumb-placeholder {
      width: 80px;
      height: 80px;
      background: #e8e0d4;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    .order-name {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--dark);
      margin-bottom: 3px;
    }

    .order-meta {
      font-size: 0.72rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .order-status {
      font-size: 0.65rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 5px 12px;
      font-weight: 600;
    }

    .status-delivered {
      background: #f0ede7;
      color: #5a4a3a;
      border: 1px solid #c9bfb0;
    }

    .status-shipped {
      background: #fdf5e6;
      color: #996600;
      border: 1px solid #e6c87a;
    }

    .status-processing {
      background: #fdf0ef;
      color: var(--accent);
      border: 1px solid #e8b5b0;
    }

    .order-price {
      font-family: var(--font-serif);
      font-size: 1.05rem;
      color: var(--dark);
      font-style: italic;
      white-space: nowrap;
      text-align: right;
    }

    .order-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }

    .address-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .address-card {
      border: 1px solid var(--light-border);
      padding: 22px 24px;
      position: relative;
      transition: border-color 0.2s;
    }

    .address-card:hover { border-color: var(--dark); }

    .address-card.default-addr {
      border-color: var(--dark);
    }

    .address-default-badge {
      font-size: 0.6rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: var(--dark);
      color: var(--cream);
      padding: 3px 9px;
      margin-bottom: 14px;
      display: inline-block;
    }

    .address-name {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--dark);
      margin-bottom: 6px;
    }

    .address-lines {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .address-actions {
      display: flex;
      gap: 10px;
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid var(--light-border);
    }

    .address-add-card {
      border: 1px dashed var(--light-border);
      padding: 22px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      cursor: pointer;
      min-height: 160px;
      transition: border-color 0.2s;
      color: var(--muted);
    }

    .address-add-card:hover {
      border-color: var(--dark);
      color: var(--dark);
    }

    .address-add-card span {
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .emprtz-tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--light-border);
      margin-bottom: 36px;
    }

    .emprtz-tab {
      font-size: 0.68rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      padding: 12px 20px;
      color: var(--muted);
      cursor: pointer;
      border: none;
      background: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: all 0.2s;
      font-family: var(--font-sans);
    }

    .emprtz-tab:hover { color: var(--dark); }
    .emprtz-tab.active { color: var(--dark); border-bottom-color: var(--dark); }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

#toastBox{
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 999999;
}

.toast{
    width: 300px;
    min-height: 60px;
    background: black;
    color: white;
    padding: 20px;
    margin-top: 15px;
    border-radius: 8px;
    font-size: 16px;
    display: flex;
    align-items: center;
}
    
   

.custom-toast {
  background: #222;
  color: #fff;
  padding: 12px 20px;
  border-radius: 6px;
  min-width: 220px;
  font-size: 14px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    transform: translateX(100%);
    opacity: 0;
  }

  to {
    transform: translateX(0);
    opacity: 1;
  }
}
   
    .emprtz-footer {
      border-top: 1px solid var(--light-border);
      padding: 30px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;
      letter-spacing: 1px;
      color: #999;
    }

    .footer-links { display: flex; gap: 24px; }

    .footer-links a {
      color: #999;
      text-decoration: none;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-size: 0.7rem;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--dark); }

    .footer-icons { display: flex; gap: 16px; }

    .footer-icons a {
      color: #999;
      font-size: 1rem;
      transition: color 0.2s;
    }

    .footer-icons a:hover { color: var(--dark); }

    @media (max-width: 900px) {
      .profile-layout {
        grid-template-columns: 1fr;
        padding: 32px 20px 60px;
      }

      .profile-sidebar {
        position: static;
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        align-items: flex-start;
      }

      .sidebar-nav {
        flex-direction: row;
        flex-wrap: wrap;
        border: 1px solid var(--light-border);
        width: 100%;
      }

      .sidebar-nav li a { border-left: none; border-bottom: 2px solid transparent; }
      .sidebar-nav li a.active { border-bottom-color: var(--accent); }

      .info-grid { grid-template-columns: 1fr; }
      .wishlist-grid { grid-template-columns: 1fr 1fr; }
      .address-grid { grid-template-columns: 1fr; }

      .profile-header { padding: 32px 20px 24px; }

      .emprtz-nav {
        padding: 16px 20px;
        flex-wrap: wrap;
        gap: 10px;
      }

      .emprtz-nav .nav-links { display: none; }
    }

    @media (max-width: 480px) {
      .wishlist-grid { grid-template-columns: 1fr; }

      .order-item {
        grid-template-columns: 60px 1fr;
      }

      .order-right { grid-column: 1 / -1; flex-direction: row; justify-content: space-between; }
    }
  </style>


  <header class="profile-header">
    <p class="page-eyebrow">Account</p>
    <h1>My Profile</h1>
  </header>

  <div class="profile-layout">

    <aside class="profile-sidebar">
      <div class="avatar-wrap">
        <span class="avatar-placeholder"></span>
      </div>

      <div class="sidebar-name" id="sidebar-name"> </div>
      <div class="sidebar-handle"></div>

      <ul class="sidebar-nav">
        <li><a href="#" class="active" data-tab="info"><i class="bi bi-person"></i> Profile</a></li>
        <li><a href="#" data-tab="orders"><i class="bi bi-bag-check"></i> Orders</a></li>
        <li><a href="#" data-tab="addresses"><i class="bi bi-geo-alt"></i> Addresses</a></li>
        <li><a href="#" data-tab="security"><i class="bi bi-shield-lock"></i> Security</a></li>
      </ul>
    </aside>

   
    <main class="profile-main">

     
      <div class="tab-panel active" id="tab-info">
        <p class="section-title">Personal Information</p>

        <div class="info-card">
          <p class="card-heading">Account Details</p>
          <div class="info-grid">
            <div class="info-field">
              <label for="firstName">First Name</label>
              <input type="text"  id="firstName" >
            </div>
            <div class="info-field">
              <label for="lastName">Last Name</label>
              <input type="text" id="lastName">
            </div>
            <div class="info-field">
              <label for="emailAddr">Email Address</label>
              <input type="email" class="form-control" id="email"  placeholder="Email">
            </div>
            <div class="info-field">
              <label for="phone">Phone Number</label>
              <input type="tel" class="form-control" id="phoneNumber"  placeholder="Phone">
            </div>
            <div class="info-field">
              <label for="dob">Date of Birth</label>
              <input type="date" class="form-control" id="dob">
            </div>
            <div class="info-field">
              <label for="gender">Gender</label>
              <select class="form-select" id="gender">
                <option>Prefer not to say</option>
                <option >Female</option>
                <option>Male</option>
                <option>Non-binary</option>
              </select>
            </div>
          </div>
          <div class="edit-actions">
            <button class="btn-emprtz btn-emprtz-primary" id="save-profile">Save Changes</button>
            <button class="btn-emprtz btn-emprtz-outline" id="cancel-profile">Cancel</button>
          </div>
        </div>
      </div>
    
      <div class="tab-panel" id="tab-orders">
        <p class="section-title">Order History</p>

        <div class="order-item">
