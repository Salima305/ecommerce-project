      <!-- ── Security Tab ── -->
      <div class="tab-panel" id="tab-security">
        <p class="section-title">Security Settings</p>

        <div class="info-card">
          <p class="card-heading">Change Password</p>
          <div style="display:flex; flex-direction:column; gap:20px; max-width:440px;">
            <div class="info-field">
              <label for="currPass">Current Password</label>
              <input type="password" class="form-control" id="currPass" placeholder="Enter current password">
            </div>
