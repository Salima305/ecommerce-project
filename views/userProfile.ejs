          </div>
        </div>

        <div class="order-item">
          <div class="order-thumb-placeholder"><i class="bi bi-gem"></i></div>
          <div>
            <div class="order-name">Rose Gold Bangles Set</div>
            <div class="order-meta">Order #EMZ-2024-0743 &nbsp;·&nbsp; 18 Jan 2025</div>
          </div>
          <div class="order-right">
            <span class="order-status status-processing">Processing</span>
            <span class="order-price">₹6,500</span>
          </div>
        </div>

        <div class="order-item">
          <div class="order-thumb-placeholder"><i class="bi bi-gem"></i></div>
          <div>
            <div class="order-name">Antique Filigree Ring</div>
