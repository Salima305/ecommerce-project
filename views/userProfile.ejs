          <div class="order-right">
            <span class="order-status status-delivered">Delivered</span>
            <span class="order-price">₹3,100</span>
          </div>
        </div>
      </div>

     
      <!-- ── Addresses Tab ── -->

       <div class="tab-panel" id="tab-addresses">
         <p class="section-title">Saved Addresses</p>
      <div class="info-card">
       <p class="card-heading">Add New Address</p>
       <div class="info-grid">
  <div class="info-field">
    <label>Full Name</label>
    <input type="text" id="fullName">
  </div>
  <div class="info-field">
    <label>House</label>
