<%- include('partials/userHeader', { title: 'cart' }) %>

<style>

  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap');

 
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background-color: #f5f0e8;
    font-family: 'Montserrat', sans-serif;
    color: #2a1a1a;
  }

 
  .cart-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }

  .cart-page h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem;
    font-weight: 400;
    color: #2a1a1a;
    margin-bottom: 6px;
  }

  .cart-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    color: #7a6a5a;
    margin-bottom: 48px;
    display: block;
  }

  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    align-items: start;
  }


  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr auto auto auto;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid #ddd5c8;
  }

  .cart-item:first-child {
    border-top: 1px solid #ddd5c8;
  }

  .cart-item img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    background: #e8e0d4;
  }

  .cart-item-info h5 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 4px;
    color: #2a1a1a;
  }

  .cart-item-info .ref {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #9a8a7a;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
  }

  /* ── Quantity Controls ── */
  .qty-control {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .qty-control button {
    width: 26px;
    height: 26px;
    background: transparent;
    border: 1px solid #c4b8a8;
    border-radius: 0;
    font-size: 1rem;
    color: #2a1a1a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .qty-control button:hover {
    background: #e8e0d4;
  }

  .qty-control span {
    font-size: 0.9rem;
    min-width: 16px;
    text-align: center;
  }

  /* ── Item Price ── */
  .item-price {
    font-size: 1rem;
    font-weight: 500;
    min-width: 80px;
    text-align: right;
  }

  /* ── Remove Button ── */
  .remove-btn {
    background: transparent;
    border: none;
    color: #9a8a7a;
    font-size: 1.1rem;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s;
  }

  .remove-btn:hover { color: #5c1a1a; }

  /* ── Order Summary Card ── */
  .order-summary {
    background: #ede8de;
    padding: 36px 32px;
  }

  .order-summary h5 {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 28px;
    color: #2a1a1a;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .summary-row .label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #7a6a5a;
    font-weight: 500;
  }

  .summary-row .value {
    font-size: 0.85rem;
    color: #2a1a1a;
  }

  .summary-divider {
    border: none;
    border-top: 1px solid #cec5b8;
    margin: 20px 0;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 28px;
  }

  .total-row .total-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    color: #2a1a1a;
  }

  .total-row .total-amount {
    font-size: 1.8rem;
    font-weight: 400;
    color: #2a1a1a;
    font-family: 'Playfair Display', serif;
  }

  /* ── Coupon Section ── */
  .coupon-section {
    margin: 4px 0 20px;
  }

  .coupon-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: #7a6a5a;
    font-weight: 500;
    font-family: 'Montserrat', sans-serif;
    display: block;
    margin-bottom: 10px;
  }

  .coupon-row {
    display: flex;
    gap: 0;
    border: 1px solid #c4b8a8;
  }

  .coupon-row input {
    flex: 1;
    padding: 11px 14px;
    background: transparent;
    border: none;
    outline: none;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    color: #2a1a1a;
    letter-spacing: 0.04em;
  }

  .coupon-row input::placeholder {
    color: #b0a090;
    font-style: italic;
  }

  .coupon-apply-btn {
    padding: 11px 18px;
    background: #5c1a1a;
    color: #f5f0e8;
    border: none;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .coupon-apply-btn:hover { background: #4a1515; }

  .coupon-msg {
    display: block;
    margin-top: 7px;
    font-size: 0.72rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    min-height: 16px;
    color: #7a6a5a;
  }

  .coupon-msg.success { color: #4a7a4a; }
  .coupon-msg.error   { color: #8a2a2a; }

  /* ── Checkout Button ── */
  .checkout-btn {
    width: 100%;
    padding: 16px;
    background: #5c1a1a;
    color: #f5f0e8;
    border: none;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    margin-bottom: 14px;
  }

  .checkout-btn:hover { background: #4a1515; }

  .btn-emprtz {
  font-size: 0.7rem;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 10px 24px;
  border-radius: 0;
  cursor: pointer;
  transition: all 0.25s;
}

.btn-emprtz-primary {
  background: #2e0303;
  color: #f5f0e8;
  border: 1px solid #2e0303;
}

.btn-emprtz-primary:hover {
  background: #c0392b;
  border-color: #c0392b;
  color: white;
}

  .secure-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 0.72rem;
    color: #7a6a5a;
  }

  .secure-badge svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* ── Footer ── */
  .collection-footer {
    border-top: 1px solid #ddd5c8;
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: #9a8a7a;
    font-family: 'Montserrat', sans-serif;
  }

  .footer-links {
    display: flex;
    gap: 28px;
  }

  .footer-links a {
    color: #9a8a7a;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #2a1a1a; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }
    .cart-item {
      grid-template-columns: 90px 1fr;
      grid-template-rows: auto auto;
    }
    .qty-control, .item-price, .remove-btn {
      grid-column: 2;
    }
  }
</style>

<div class="cart-page">
  <div class="d-flex justify-content-between align-items-center">
    <h2>Shopping Bag</h2>
    <button id="clearCartBtn" class="btn btn-primary">Clear Cart</button>
  </div>
  <span class="cart-subtitle">Your curated selection of heirlooms</span>
  <div class="cart-layout">

   
    <div id="cart-items">

      
    </div>

    
    <div class="order-summary">
      <h5>Order Summary</h5>

      <div class="summary-row">
        <span class="label">SUBTOTAL</span>
        <span class="value" id="subtotal"></span>
      </div>

      <div class="summary-row">
        <span class="label">SHIPPING</span>
        <span class="value" id="shipping"></span>
      </div>

      <hr class="summary-divider" />

  
      <div class="coupon-section">
        <span class="coupon-label">HAVE A COUPON?</span>
        <div class="coupon-row">
          <input type="text" id="coupon-input" placeholder="Enter Coupon Code" autocomplete="off" />
          <button class="coupon-apply-btn" id="apply-coupon">APPLY</button>
        </div>
        <span class="coupon-msg" id="coupon-msg"></span>
      </div>

         <div class="summary-row">
        <span class="label">DISCOUNT AMOUNT</span>
        <span class="value" id="discount"></span>
      </div>

      <hr class="summary-divider" />

      <div class="total-row">
        <span class="total-label">Total Amount</span>
        <span class="total-amount" id="total"></span>
      </div>

      <button id="checkout-btn" class="btn-emprtz btn-emprtz-primary">PROCEED TO CHECKOUT</button>

      <div class="secure-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Secured Heirloom Transaction
      </div>
    </div>

  </div>
</div>

<%- include('partials/userFooter') %>

<script src="cart.js"></script>
<!-- <script src="checkout.js"></script> -->