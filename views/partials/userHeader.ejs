<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;500&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f5f0e8;
      --dark: #1a1a1a;
      --accent: #8b6f4e;
      --light-border: #e0d8cc;
    }

    body {
      background-color: var(--cream);
      color: var(--dark);
      font-family: 'Cormorant Garamond', serif;
    }
@media (max-width: 768px) {
  .nav-right {
    display: none;
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
  }

  .user-dropdown {
    position: relative;
    width: fit-content;
  }

  .dropdown-menu-custom {
    left: 0;
    right: auto;
    top: 100%;
  }
}
  
    .emprtz-nav {
      background-color: var(--cream);
      border-bottom: 1px solid var(--light-border);
      padding: 16px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      font-family:'Cormorant Garamond', serif ;
      font-style: italic;
      font-size: 1.4rem;
      font-weight: 700;
      color: #2e0202;
      text-decoration: none;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .nav-middle a {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color:  #2e0202;
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-middle a:hover {
      color: var(--accent);
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

  
    .search-wrapper {
      display: flex;
      align-items: center;
      border-bottom: 1px solid  #2e0202;
      padding-bottom: 2px;
    }

    .search-wrapper input {
      background: transparent;
      border: none;
      outline: none;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.85rem;
      letter-spacing: 1px;
      width: 140px;
      color:  #2e0202;
    }

    .search-wrapper input::placeholder {
      color: #999;
    }

    .search-wrapper i {
      font-size: 0.85rem;
      color: #2e0202;
      cursor: pointer;
    }


    .nav-icon {
      font-size: 1.1rem;
      color:  #2e0202;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s;
      position: relative;
    }


.hamburger {
  display: none;
  background: none;
  border: none;
  font-size: 1.6rem;
  color: #2e0202;
  cursor: pointer;
}


@media (max-width: 768px) {
  .emprtz-nav {
    flex-wrap: wrap;
    padding: 16px 20px;
  }

  .hamburger {
    display: block;
  }

  .nav-middle,
  .nav-right {
    display: none;
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 0;
    border-top: 1px solid var(--light-border);
  }

  .nav-middle.open,
  .nav-right.open {
    display: flex;
  }

  .search-wrapper input {
    width: 100%;
  }
}

    .cart-wrapper{
   position: relative;
    }

   #cart-count{
   position:absolute;
   top:-8px;
   right:-10px;

   min-width:18px;
   height:18px;
   padding:0 4px;

   border-radius:50%;

   background:#5a0f0f;
   color:#f5f0e8;

   font-family:Arial,sans-serif;
   font-size:10px;
   font-weight:600;
   line-height:1;

   display:flex;
   align-items:center;
   justify-content:center;

   box-sizing:border-box;
}
    .nav-icon:hover { color: var(--accent); }

    body.showCart.cartTab{
      inset:0 0 0 auto;
    }

    body.showCart.container{
      transform:translateX(-250px)
    }

    .container{
      transition: transform 0.5s;
    }
    .user-dropdown {
      position: relative;
    }

    .dropdown-menu-custom {
      display: none;
      position: absolute;
      right: 0;
      top: 130%;
      background: var(--cream);
      border: 1px solid var(--light-border);
      min-width: 140px;
      z-index: 9999;
      padding: 8px 0;
    }

    
    .dropdown-menu-custom.show{
    display:block;
}

    .dropdown-menu-custom a,
    .dropdown-menu-custom button {
      display: block;
      width: 100%;
      padding: 10px 18px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      letter-spacing: 1px;
      color: #2e0202;
      text-decoration: none;
      background: none;
      border: none;
      text-align: left;
      cursor: pointer;
      transition: 'background', 0.2s;
    }

    .dropdown-menu-custom a:hover,
    .dropdown-menu-custom button:hover {
      background: var(--light-border);
    }
    .user-icon{
    display:flex;
    align-items:center;
    justify-content:center;
}
  </style>
</head>
<body>

<nav class="emprtz-nav">
  
  <a href="/home" class="nav-logo">Emprtz</a>
<button class="hamburger" id="hamburger">
  <i class="bi bi-list"></i>
</button>
  
  <div class="nav-middle">
    <a href="/collection">Collection</a>
  </div>

  
  <div class="nav-right">
  
    <form action="/collection" method="GET" class="search-wrapper">
      <input type="text" name="search" placeholder="Search...">
      <i class="bi bi-search"></i>
    </form>

   <div class="cart-wrapper">
    <a href="/cart" class="nav-icon"> <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
  <path d="M12.268 6A2 2 0 0 0 14 9h1v1a2 2 0 0 0 3.04 1.708l-.311 1.496a1 1 0 0 1-.979.796H8.605l.208 1H16a3 3 0 1 1-2.83 2h-2.34a3 3 0 1 1-4.009-1.76L4.686 5H4a1 1 0 0 1 0-2h1.5a1 1 0 0 1 .979.796L6.939 6h5.329Z"/>
  <path d="M18 4a1 1 0 1 0-2 0v2h-2a1 1 0 1 0 0 2h2v2a1 1 0 1 0 2 0V8h2a1 1 0 1 0 0-2h-2V4Z"/>
</svg>
</a>
<span id="cart-count">0</span>
</div>

    <div class="user-dropdown">
      <span class="nav-icon user-icon" id="user-icon"><i ><svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
  <path fill-rule="evenodd" d="M12 20a7.966 7.966 0 0 1-5.002-1.756l.002.001v-.683c0-1.794 1.492-3.25 3.333-3.25h3.334c1.84 0 3.333 1.456 3.333 3.25v.683A7.966 7.966 0 0 1 12 20ZM2 12C2 6.477 6.477 2 12 2s10 4.477 10 10c0 5.5-4.44 9.963-9.932 10h-.138C6.438 21.962 2 17.5 2 12Zm10-5c-1.84 0-3.333 1.455-3.333 3.25S10.159 13.5 12 13.5c1.84 0 3.333-1.455 3.333-3.25S13.841 7 12 7Z" clip-rule="evenodd"/>
</svg>
</i></span>
      <!-- <div class="dropdown-menu-custom" id="user-menu">
        <a href="/userProfile">Profile</a>
        <a href="/logout">Logout</a>
      </div> -->
      <div class="dropdown-menu-custom" id="user-menu">

  <% if (user) { %>
    <a href="/userProfile">Profile</a>
    <a href="/logout">Logout</a>
  <% } else { %>
    <a href="/login">Login</a>
    <a href="/signup">Sign Up</a>
  <% } %>

</div>
    </div>
  </div>
</nav>
<script src="/main.js"></script>
<script>

const userIcon =
document.getElementById("user-icon")

const userMenu =
document.getElementById("user-menu")

userIcon.addEventListener("click", (e) => {

    e.stopPropagation()

    userMenu.classList.toggle("show")
})

document.addEventListener("click", () => {

    userMenu.classList.remove("show")
})

userMenu.addEventListener("click", (e) => {

    e.stopPropagation()
})

const hamburger=document.getElementById('hamburger')
const navMiddle=document.querySelector('.nav-middle')
const navRight=document.querySelector('.nav-right')

hamburger.addEventListener('click',()=>{
  navMiddle.classList.toggle('open')
  navRight.classList.toggle('open')
})

</script>
