<%- include('partials/header', { title: 'Orders' }) %>

<div class="container-fluid">
  <div class="row">

    <div class="col-md-2 sidebar">
      <%- include('partials/sidebar') %>
    </div>

    <div class="col-md-10">

      <!-- Top Bar -->
      <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom bg-white shadow-sm">
        <h4 class="mb-0 fw-bold">📦 Order Management</h4>
        <!-- <a href="/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a> -->
      </div>

      <div class="p-4" style="background:#f1f5f9; min-height:100vh;">

        <div class="card border-0 shadow-sm rounded-4 p-4">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Date</th>
                <th>Update</th>
              </tr>
            </thead>
            <tbody id="orders-table-body">
              <tr>
                <td colspan="8" class="text-center">Loading...</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="/adminOrders.js"></script>