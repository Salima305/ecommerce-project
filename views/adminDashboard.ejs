
<%- include('partials/header', { title: 'Dashboard' }) %>

<div class="container-fluid">
  <div class="row">

    <div class="col-md-2 sidebar">
      <%- include('partials/sidebar') %>
    </div>

    <div class="col-md-10">

      <!-- Top Bar -->
      <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom bg-white shadow-sm">
        <h4 class="mb-0 fw-bold">📊 Dashboard</h4>
        <div class="d-flex align-items-center gap-3">
          <span class="text-muted">Welcome, <strong>Admin</strong></span>
          <a href="/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
        </div>
      </div>

      <div class="p-4" style="background:#f1f5f9; min-height:100vh;">

        <!-- Stats Cards -->
        <div class="row mb-4 g-3">

          <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1 small">Total Users</p>
                  <h3 class="fw-bold mb-0"><%= totalUsers %></h3>
                </div>
                <div style="background:#ede9fe; padding:15px; border-radius:12px;">
                  <i class="bi bi-people-fill" style="font-size:1.5rem; color:#7c3aed;"></i>
                </div>
              </div>
            
            </div>
          </div>

          <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1 small">Total Products</p>
                  <h3 class="fw-bold mb-0"><%= totalProducts %></h3>
                </div>
                <div style="background:#dcfce7; padding:15px; border-radius:12px;">
                  <i class="bi bi-box-fill" style="font-size:1.5rem; color:#16a34a;"></i>
                </div>
              </div>
        
            </div>
          </div>

          <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1 small">Total Orders</p>
                  <h3 class="fw-bold mb-0"><%= totalOrders %></h3>
                </div>
                <div style="background:#fef9c3; padding:15px; border-radius:12px;">
                  <i class="bi bi-cart-fill" style="font-size:1.5rem; color:#ca8a04;"></i>
                </div>
              </div>
        
            </div>
          </div>

          <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1 small">Revenue</p>
                  <h3 class="fw-bold mb-0"><%= totalRevenue %></h3>
                </div>
                <div style="background:#fee2e2; padding:15px; border-radius:12px;">
                  <i class="bi bi-currency-rupee" style="font-size:1.5rem; color:#dc2626;"></i>
                </div>
              </div>
    
            </div>
          </div>

        </div>

        <!-- Quick Links -->
        <div class="row g-3">
          <div class="col-md-12">
            <div class="card border-0 shadow-sm rounded-4 p-4">
              <h5 class="fw-bold mb-3">Quick Actions</h5>
              <div class="d-flex gap-3 flex-wrap">
                <a href="/admin/users" class="btn btn-outline-primary">
                  <i class="bi bi-people me-2"></i>Manage Users
                </a>
                <a href="/admin/products" class="btn btn-outline-success">
                  <i class="bi bi-box me-2"></i>Manage Products
                </a>
                <a href="/admin/categories" class="btn btn-outline-warning">
                  <i class="bi bi-tags me-2"></i>Manage Categories
                </a>
                <a href="/admin/orders-page" class="btn btn-outline-danger">
                  <i class="bi bi-box-seam me-2"></i>Orders
                </a>
                <a href="/admin/coupons" class="btn btn-outline-secondary">
                  <i class="bi bi-ticket-perforated me-2"></i>Manage Coupons
                </a>
                 <a href="/admin/analytics-page" class="btn btn-outline-info">
                  <i class="bi bi-graph-up me-2"></i>Analytics
                </a>

              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>